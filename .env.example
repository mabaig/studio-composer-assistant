# Composer API
COMPOSER_API_URL=https://copilot-chat.intellinum.com/composer_skills/stream
COMPOSER_API_TOKEN=

# PostgreSQL — Neon (recommended): set DATABASE_URL from your Neon dashboard
# Neon connection string looks like:
#   postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Local PostgreSQL alternative (only used if DATABASE_URL is not set)
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=scm_apis
# PG_USER=postgres
# PG_PASSWORD=
